# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
insert_final_newline = true

[*.md]
indent_size = 4

[*.sh]
indent_size = 4

[*.py]
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4
