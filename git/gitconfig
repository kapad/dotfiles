[pull]
  rebase = false

[alias]
  lgsummary = "log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit"
  pushup = "!git push --set-upstream origin $(git symbolic-ref --short HEAD)"

[push]
  default = upstream

